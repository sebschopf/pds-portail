# Variables d'environnement backend PDS-Portail
# Copier ce fichier en .env.local pour un usage local (recommande).
# Ne jamais committer de fichier .env/.env.local contenant des valeurs réelles.
#
# Tests:
# - La suite pytest force un fichier dedie via PDS_ENV_FILES=.env.test
# - Garder .env.test hors git et sans secrets reels
#
# Configuration Render (production) :
# Ces variables sont définies via le dashboard Render (Settings > Environment).
# Voir render.yaml (blueprint) ou la configuration manuelle du service.

# URL de la base de données SQLite (locale) ou PostgreSQL (future)
# Render avec disque persistant: sqlite:////var/data/app.db
DATABASE_URL=sqlite:///./data/app.db

# URL de base de l'API CKAN opendata.swiss
CKAN_BASE_URL=https://opendata.swiss

# Origines CORS autorisées (séparées par des virgules si plusieurs)
# Production : https://pds-portail.vercel.app
# Local : http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Exposition des docs OpenAPI (/docs, /redoc, /api/v1/openapi.json)
# Production : false (sécurité, pas d'exposition publique)
# Local : true (développement)
EXPOSE_API_DOCS=true

# SMTP (alertes email watchers)
# Brevo SMTP relay:
# - hote: smtp-relay.brevo.com
# - port TLS: 587
# - user: identifiant SMTP Brevo (ex: xxxxx@smtp-brevo.com)
# - password: clé SMTP Brevo (ne jamais committer)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Adresse expéditeur validée dans Brevo (sender identity)
SMTP_FROM=

# Limite de sécurité locale/production pour les envois d'alertes par cycle
SMTP_DAILY_LIMIT=50

# Polar (Merchant of Record pour surveillance datasets)
# Config canonique : voir R006 §4.
#
# POLAR_WEBHOOK_SECRET (backend): secret webhook pour vérification HMAC-SHA256.
#   Récupérer depuis le dashboard Polar > Webhooks > Secret.
#   Sans cette variable, l'endpoint /api/v1/webhooks/polar retourne 503.
POLAR_WEBHOOK_SECRET=
#
# Remarque : les variables PUBLIC_POLAR_* sont frontend SvelteKit uniquement.
#   Voir frontend/.env.local et le dashboard Vercel pour la production :
#   - PUBLIC_POLAR_CHECKOUT_URL : URL checkout link hébergé (mode prioritaire)
#     Format: https://buy.polar.sh/... (pas checkout.polar.sh)
#   - PUBLIC_POLAR_PRODUCT_ID : ID produit Polar (fallback legacy)

# Token interne partage entre backend et frontend SSR
# Utilise pour authentifier les appels /api/v1/internal/support/*
# IMPORTANT: la valeur doit etre identique cote backend et cote frontend (Vercel SSR)
INTERNAL_API_TOKEN=

# Guard sur l'accès du module support protégé (gestion des watchers)
# Ces identifiants sont utilisés pour l'authentification HTTP Basic sur la route /support interne.
# Production
SUPPORT_INTERNAL_USERNAME=
SUPPORT_INTERNAL_PASSWORD=