# Variables d'environnement frontend PDS-Portail
# Copier ce fichier en .env.local pour un usage local.
# Ne jamais committer de fichier .env.local ou .env contenant des valeurs réelles.

# URL de base de l'API backend (mode dev normal — backend réel)
# Valeur par défaut dans vite.config.ts : http://127.0.0.1:8000
# PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Activation du mode mock local (QA/dev sans backend)
# INTERDIT en production. Laisser vide ou absent pour le mode normal.
# Valeur autorisée uniquement en dev local : 1
# PUBLIC_USE_MOCK_API=1
