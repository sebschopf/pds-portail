{
	"name": "frontend",
	"private": true,
	"version": "1.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:mock": "PUBLIC_USE_MOCK_API=1 vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"validate:design": "node ./scripts/validate-design-system.mjs",
		"lighthouse:desktop": "node ./scripts/run-lighthouse-profile.mjs desktop",
		"lighthouse:mobile": "node ./scripts/run-lighthouse-profile.mjs mobile",
		"lighthouse:all": "npm run lighthouse:desktop && npm run lighthouse:mobile",
		"lighthouse:suite": "node ./scripts/run-lighthouse-suite.mjs",
		"validate:js-delivery": "node ./scripts/validate-js-delivery.mjs",
		"quality:frontend": "npm run check && npm run validate:design && npm run build && npm run lighthouse:suite"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"lighthouse": "^13.4.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.0.8"
	},
	"dependencies": {
		"culori": "^4.0.2"
	}
}
