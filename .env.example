# Variables d'environnement backend PDS-Portail
# Copier ce fichier en .env pour un usage local.
# Ne jamais committer de fichier .env contenant des valeurs réelles.
#
# Configuration Render (production) :
# Ces variables sont définies via le dashboard Render (Settings > Environment).
# Voir render.yaml (blueprint) ou la configuration manuelle du service.

# URL de la base de données SQLite (locale) ou PostgreSQL (future)
DATABASE_URL=sqlite:///./data/app.db

# URL de base de l'API CKAN opendata.swiss
CKAN_BASE_URL=https://opendata.swiss

# Origines CORS autorisées (séparées par des virgules si plusieurs)
# Production : https://pds-portail.vercel.app
# Local : http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Exposition des docs OpenAPI (/docs, /redoc, /api/v1/openapi.json)
# Production : false (sécurité, pas d'exposition publique)
# Local : true (développement)
EXPOSE_API_DOCS=true